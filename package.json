{
    "name": "v8-shape",
    "version": "0.1.0",
    "description": "Mechanical-sympathy primitives for packed V8 arrays and monomorphic plain-object shapes, with engine-level receipts.",
    "keywords": [
        "v8",
        "performance",
        "packed-array",
        "elements-kind",
        "hidden-class",
        "monomorphic",
        "array",
        "optimization"
    ],
    "license": "MIT",
    "author": "Xyra Sinclair",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/XyraSinclair/v8-shape.git"
    },
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "DESIGN.md"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
        "build": "npm run clean && tsc -p tsconfig.build.json",
        "test": "vitest run",
        "bench": "npm run build && node bench/receipts.mjs",
        "release": "npm publish --access public",
        "prepack": "npm run build",
        "prepublishOnly": "npm run test && npm run build"
    },
    "devDependencies": {
        "@types/node": "^26.1.0",
        "cyclebench": "^0.1.0",
        "isoequal": "^1.0.0",
        "typescript": "^5.5.0",
        "vitest": "^3.2.7"
    }
}
